# -*- coding: utf-8 -*-import pandas as pdimport arcpyclass Toolbox(object):    def __init__(self):        """Define the toolbox (the name of the toolbox is the name of the        .pyt file)."""        self.label = "yilinpu_586"        self.alias = "yilinpu_586"        # List of tool classes associated with this toolbox        self.tools = [yilinpu_586]class yilinpu_586(object):    def __init__(self):        """Define the tool (tool name is the name of the class)."""        self.label = "yilinpu_586"        self.description = "It uses the staitiscs of boxplot to calculate the quantiles " \                           "to classify the data into six categories except the missing values)"        self.canRunInBackground = False    def getParameterInfo(self):        input1 = arcpy.Parameter(            name="input_feature",            displayName="Input Feature",            datatype="GPFeatureLayer",            parameterType="Required",            direction="Input")        input2 = arcpy.Parameter(            name="input_table",            displayName="Input Table",            datatype="Table",            parameterType="Required",            direction="Input")        input3 = arcpy.Parameter(            name="input_field",            displayName="Input Field",            datatype="Field",            parameterType="Required",            direction="Input")        output = arcpy.Parameter(            name="output_feature",            displayName="Output Feature",            datatype="GPFeatureLayer",            parameterType="Required",            direction="Output")        parameters = [input1, input2, input3, output]        return parameters    def execute(self, parameters, messages):        inputfc1 = parameters[0].valueAsText        inputfc2 = parameters[1].valueAsText        inputfc3 = parameters[2].valueAsText        outputfc = parameters[3].valueAsText        # Read Excel file        str1 = inputfc2.replace(r"\Sheet1$", "")        str2 = str1.replace("\\", "/")        df = pd.read_excel(str2)        classify = []        inputfc3 = int(inputfc3)        # Calculate IQR        Median = df[inputfc3].quantile(0.5)        Q1 = df[inputfc3].quantile(0.25)        Q3 = df[inputfc3].quantile(0.75)        IQR = Q3 - Q1        # Classify        for i in df[inputfc3]:            if i >= (Q3 + 1.5 * IQR):                classify.append('OutliersOverQ3')            elif (Q1 - 1.5 * IQR) < i <= Q1:                classify.append('< 25%')            elif Q3 <= i < (Q3 + 1.5 * IQR):                classify.append('> 75%')            elif i <= (Q1 - 1.5 * IQR):                classify.append('OutliersBelowQ1')            elif Median <= i < Q3:                classify.append('50%-75%')            elif Q1 < i < Median:                classify.append('25%-50%')            else:                classify.append('missing value')        df['classify'] = classify        str3 = str2[0:2]        df.to_excel(str3 + "/output.xlsx")        # Set local variables        inFeatures = inputfc1        joinTable = str3 + "/output.xlsx/Sheet1$"        joinField = "COUNTY_NAM"        # Join the feature layer to a table        joined_table = arcpy.AddJoin_management(inFeatures, joinField, joinTable, joinField)        # Copy the layer to a new permanent feature class        arcpy.CopyFeatures_management(joined_table, outputfc)